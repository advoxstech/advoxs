    {"type":"text","id":"evidence1_t","x":630,"y":335,"width":500,"height":140,"text":"SELECT tenant_id FROM whatsapp_numbers\n  WHERE phone_number_id = :id\n\nINSERT INTO messages (sender_type='contact', ...)\n\n-- após commit --\nenqueue('process_inbound_message',\n        tenant_id, conversation_id, message_id)","originalText":"SELECT tenant_id FROM whatsapp_numbers\n  WHERE phone_number_id = :id\n\nINSERT INTO messages (sender_type='contact', ...)\n\n-- após commit --\nenqueue('process_inbound_message',\n        tenant_id, conversation_id, message_id)","fontSize":14,"fontFamily":3,"textAlign":"left","verticalAlign":"top","strokeColor":"#22c55e","containerId":"evidence1_box"},

