# OpenAI (embeddings densos + LLM do HyDE/keywords)
OPENAI_API_KEY=

# Postgres (metadados dos documentos)
POSTGRES_USER=advoxs
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=advoxs_rag

# Qdrant — collection única, isolamento por tenant_id (payload indexado)
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=advoxs_kb
DENSE_VECTOR_SIZE=1536

# Modelos
DENSE_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-5-mini

# Retrieval
TOP_K=5
PREFETCH_K=20

# API de sparse embedding (HTTP própria)
URL_API_LOCAL_SPARSE=http://sparse:8000/embed

# Armazenamento dos arquivos crus
UPLOAD_DIR_USER=/data/uploads/users
UPLOAD_DIR_SYSTEM=/data/uploads/system

# Auth de serviço interno (header Authorization) — só agents/api/worker chamam
API_KEY=changeme
