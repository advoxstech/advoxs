# RAG / Retrieval
RAG_API_URL=
RAG_API_KEY=

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL — checkpoint do LangGraph (database dedicado advoxs_agents,
# criado por infra/postgres/init/002-databases.sh no compose do monorepo)
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=advoxs_agents
DATABASE_NAME=advoxs_agents
DATABASE_PASSWORD=

# OpenAI
OPENAI_API_KEY=

# Auth interna (o `api` chama este serviço com Authorization: <AGENTS_API_KEY>)
# Se vazio, a verificação é desligada (dev local).
AGENTS_API_KEY=

# WhatsApp Cloud API (Graph API da Meta)
# As credenciais por tenant (phone_number_id, access_token) chegam em cada
# request — aqui só a base/versão da Graph API.
GRAPH_API_BASE_URL=https://graph.facebook.com
GRAPH_API_VERSION=v23.0

# Langfuse
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# Logging
LOG_FILE=logs/api.log
