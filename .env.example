# Postgres — instância única, um database por serviço:
#   advoxs (api/worker) | advoxs_agents (checkpoint LangGraph) | advoxs_rag (docs RAG)
# Roles/databases criados por infra/postgres/init/002-databases.sh na 1ª subida.
POSTGRES_USER=advoxs
POSTGRES_PASSWORD=changeme
POSTGRES_DB=advoxs
DATABASE_URL=postgresql+asyncpg://advoxs:changeme@postgres:5432/advoxs
AGENTS_DB_PASSWORD=changeme
RAG_DB_PASSWORD=changeme

# Redis
REDIS_URL=redis://redis:6379/0

# Qdrant
QDRANT_URL=http://qdrant:6333

# Auth
JWT_SECRET=changeme
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# WhatsApp Cloud API (Embedded Signup — app da plataforma, não por tenant)
META_APP_ID=
META_APP_SECRET=
# Token combinado com a Meta na configuração do webhook (GET de verificação)
META_VERIFY_TOKEN=changeme
# Chave Fernet (base64, 32 bytes) para cifrar whatsapp_numbers.access_token_encrypted
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
WHATSAPP_TOKEN_ENCRYPTION_KEY=

# Agents service
AGENTS_SERVICE_URL=http://agents:8001
# Auth de serviço interno (header Authorization nas chamadas api/worker -> agents)
AGENTS_API_KEY=

# RAG service (api_rag) — auth de serviço interno (agents/api/worker -> api_rag)
RAG_API_KEY=changeme

# LLM / embeddings (consumido por agents e api_rag)
OPENAI_API_KEY=
DENSE_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-5-mini
DENSE_VECTOR_SIZE=1536
QDRANT_COLLECTION=advoxs_kb
# API HTTP de sparse embedding (serviço externo ao monorepo)
URL_API_LOCAL_SPARSE=http://sparse:8000/embed

# Langfuse (tracing dos agentes — opcional em dev)
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# Créditos: 1 crédito = N tokens (ceil; valor de partida, calibrar com custo real)
CREDIT_TOKENS_PER_CREDIT=1000

# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
# Base do api para chamadas server-side do Next (proxy/actions). No compose: http://api:8000
API_URL=http://localhost:8000
